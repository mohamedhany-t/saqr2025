rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper Functions to check user roles
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isCompany() {
      return exists(/databases/$(database)/documents/roles_company/$(request.auth.uid));
    }

    function isCourier() {
      return exists(/databases/$(database)/documents/roles_courier/$(request.auth.uid));
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    // -- App Settings --
    // settings/system_settings, governorates, custom_statuses
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /governorates/{docId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    match /custom_statuses/{docId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    // -- Core Data --
    match /shipments/{shipmentId} {
      allow read: if isAdmin() || 
                     (isCompany() && resource.data.companyId == request.auth.uid) ||
                     (isCourier() && resource.data.assignedCourierId == request.auth.uid);
      
      allow create: if isAdmin() || isCompany();

      allow update: if isAdmin() || 
                       (isCompany() && request.resource.data.companyId == request.auth.uid) ||
                       (isCourier() && request.resource.data.assignedCourierId == request.auth.uid);

      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn(); // Allow reading other user profiles for names/roles
      allow update: if isAdmin() || request.auth.uid == userId; // Allow users to update their own profile (e.g. avatar)
      allow create, delete: if isAdmin();
    }
    
    match /companies/{companyId} {
       allow read: if isSignedIn();
       allow create, update, delete: if isAdmin();
    }

    match /couriers/{courierId} {
       allow read: if isSignedIn();
       allow create, update, delete: if isAdmin();
    }

    // -- Financials --
    match /courier_payments/{paymentId} {
        allow read: if isAdmin() || (isCourier() && resource.data.courierId == request.auth.uid);
        allow create, update, delete: if isAdmin();
    }
    
    match /company_payments/{paymentId} {
        allow read: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
        allow create, update, delete: if isAdmin();
    }
    
    // -- Chat --
    match /chats/{chatId} {
      allow read, update: if request.auth.uid in resource.data.participants;
      allow create: if isAdmin();
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read, create: if exists(/databases/$(database)/documents/chats/$(chatId)) &&
                           request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
    
     match /users/{userId}/pushSubscriptions/{subscriptionId} {
        allow write: if request.auth.uid == userId;
        allow read: if isAdmin(); // Or more restrictive if needed
     }

    // -- Roles (write-only for admin, read not needed by client) --
    match /roles_admin/{userId} {
      allow write: if isAdmin();
    }
    match /roles_company/{userId} {
      allow write: if isAdmin();
    }
    match /roles_courier/{userId} {
      allow write: if isAdmin();
    }
  }
}
