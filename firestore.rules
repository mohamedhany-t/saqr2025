rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      // Use exists() for a robust check that doesn't depend on document content.
      return exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }

    function isCompany() {
      return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isShipmentOwner(shipmentDoc) {
        return isCompany() && shipmentDoc.companyId == request.auth.uid;
    }
    
    function isShipmentCourier(shipmentDoc) {
        return isCourier() && shipmentDoc.assignedCourierId == request.auth.uid;
    }

    // --- Admin Catch-All ---
    // A single, powerful rule to grant admins full access to everything.
    // This rule is evaluated first. If it passes, access is granted.
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // --- User Profiles ---
    // Any signed-in user can read any profile.
    // A user can only update their own profile.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId);
    }

    // --- Static/Public Data ---
    // Any signed-in user can read these collections.
    // Writes are admin-only (covered by the catch-all).
    match /governorates/{docId} {
      allow read: if isSignedIn();
    }
    match /companies/{docId} {
      allow read: if isSignedIn();
    }
    match /couriers/{docId} {
      allow read: if isSignedIn();
    }

    // --- Shipments ---
    // These rules are for non-admin users.
    match /shipments/{shipmentId} {
      // Company can read its own shipments.
      // Courier can read shipments assigned to them.
      allow read: if isShipmentOwner(resource.data) || isShipmentCourier(resource.data);

      // Company can create shipments for itself.
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid;

      // Company can update its own shipments.
      // Courier can only update status, reason, and financial fields on assigned shipments.
      allow update: if isShipmentOwner(resource.data) ||
                    (isShipmentCourier(resource.data)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));

      // Company can delete its own shipments.
      allow delete: if isShipmentOwner(resource.data);
    }

    // --- Chat ---
    // Explicit rules for chat collections for non-admin users.
    // Admins are already covered by the global rule.
    match /chats/{courierId} {
      // A courier can access their own chat document.
      allow get: if isCourier() && isOwner(courierId);
      // A courier can update their own chat document (e.g., lastMessage).
      allow update: if isCourier() && isOwner(courierId);

      // Explicit rules for the messages subcollection.
      match /messages/{messageId} {
        // A courier can list and read messages in their own chat.
        allow list, get: if isCourier() && isOwner(courierId);
        // A courier can create (send) messages in their own chat.
        allow create: if isCourier() && isOwner(courierId);
      }
    }

    // --- Role Documents ---
    // Lock down role collections. Writes should only be done by admin (covered by catch-all).
    // No one else should be able to read or write these.
    match /roles_admin/{docId} { allow read, write: if false; }
    match /roles_company/{docId} { allow read, write: if false; }
    match /roles_courier/{docId} { allow read, write: if false; }
  }
}
