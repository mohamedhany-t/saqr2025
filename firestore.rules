
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isUserRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return isUserRole('admin');
    }

    // --- Collections ---

    // Users: Users can read their own data. Admins can read all user data.
    // User creation/deletion is handled by server-side actions.
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow update: if isUser(userId) || isAdmin();
      allow create, delete: if isAdmin(); // Only admins via server-action
    }

    // Roles: Read-only for security rule checks. Written by server-side actions.
    match /roles_admin/{userId} { allow read: if isSignedIn(); }
    match /roles_company/{userId} { allow read: if isSignedIn(); }
    match /roles_courier/{userId} { allow read: if isSignedIn(); }
    
    // Companies & Couriers: Public profiles. Writable by admins via server actions.
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow update, create, delete: if isAdmin();
    }
    match /couriers/{courierId} {
      allow read: if isSignedIn();
      allow update, create, delete: if isAdmin();
    }

    // Shipments: Detailed rules per role
    match /shipments/{shipmentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      // Admin: Full access
      allow create, delete, update: if isAdmin();
      
      // Company: Can create shipments for themselves. Can update shipments they own.
      allow create: if isUserRole('company') && request.resource.data.companyId == request.auth.uid;
      allow update: if isUserRole('company') && resource.data.companyId == request.auth.uid;
      
      // Courier: Can only update specific fields of their assigned shipments.
      allow update: if isUserRole('courier')
                      && resource.data.assignedCourierId == request.auth.uid
                      && request.resource.data.keys().hasOnly(['status', 'reason', 'collectedAmount', 'paidAmount', 'courierCommission', 'companyCommission', 'updatedAt']);
    }
    
    // Governorates: Writable only by Admin from the settings page. Readable by all.
    match /governorates/{governorateId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    
    // Payments (Company & Courier): Created/managed by Admin.
    match /company_payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
     match /courier_payments/{paymentId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    
    // Chat: Only participants can read/write.
    match /chats/{chatId} {
        allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.participants;
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
        
        match /messages/{messageId} {
            allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
            allow update, delete: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
        }
    }
    
    // Push Subscriptions: Users can only manage their own subscriptions.
    match /users/{userId}/pushSubscriptions/{subscriptionId} {
        allow read, write, delete: if isUser(userId);
    }
    
    // Settings: Readable by all authenticated users, writable only by admins.
    match /settings/system_settings {
        allow get: if isSignedIn();
        allow write: if isAdmin();
    }
  }
}
