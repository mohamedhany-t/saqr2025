
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    
    function isCompany() {
      return isSignedIn() && getUserRole() == 'company';
    }

    function isCourier() {
      return isSignedIn() && getUserRole() == 'courier';
    }

    // --- Collections ---

    // Settings can be read by any authenticated user, but only written by admins.
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Governorates can be read by any authenticated user, but only written by admins.
    match /governorates/{governorateId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    // Users can read their own data. Admins can read/write any user data.
    // Other users can read limited user data (e.g., for chat lists).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if request.auth.uid == userId || isAdmin();
      allow create, delete: if isAdmin();
    }
    
    match /companies/{companyId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    match /couriers/{courierId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }

    // Shipments have role-based access.
    match /shipments/{shipmentId} {
      allow read, write: if isAdmin();
      allow read, update: if isCourier() && resource.data.assignedCourierId == request.auth.uid;
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid;
      allow read, update: if isCompany() && resource.data.companyId == request.auth.uid;
    }
    
    // Payments can be read by involved parties, written only by admin.
    match /courier_payments/{paymentId} {
        allow read, write: if isAdmin();
        allow read: if isCourier() && resource.data.courierId == request.auth.uid;
    }
    
    match /company_payments/{paymentId} {
        allow read, write: if isAdmin();
        allow read: if isCompany() && resource.data.companyId == request.auth.uid;
    }
    
    // Chats are restricted to participants.
    match /chats/{chatId} {
      allow read, update: if request.auth.uid in resource.data.participants;
      allow create: if isAdmin() && request.resource.data.participants[0] == request.auth.uid;

      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
    
    // Push subscriptions are private to each user.
    match /users/{userId}/pushSubscriptions/{subscriptionId} {
        allow read, write, delete: if request.auth.uid == userId;
    }

    // Legacy role collections are only writable by admin for setup.
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
     match /roles_company/{userId} {
      allow read, write: if isAdmin();
    }
     match /roles_courier/{userId} {
      allow read, write: if isAdmin();
    }
  }
}
