

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin is defined by a specific email address for simplicity and reliability.
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'mhanyt21@gmail.com';
    }

    function isCompany() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_company/$(request.auth.uid));
    }

    function isCourier() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_courier/$(request.auth.uid));
    }
    
    // --- Collections ---

    // Users can read their own profile, admins can manage all profiles.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, delete: if isAdmin();
      
      // Allow users to manage their own push subscriptions
      match /pushSubscriptions/{subscriptionId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Shipments can be read by their owner (company), the assigned courier, or an admin.
    // Creation is for companies and admins.
    // Updates are restricted for couriers.
    match /shipments/{shipmentId} {
      allow read: if isAdmin() || 
                     (isCompany() && resource.data.companyId == request.auth.uid) || 
                     (isCourier() && resource.data.assignedCourierId == request.auth.uid);
                     
      allow create: if isAdmin() || 
                       (isCompany() && request.resource.data.companyId == request.auth.uid);
                       
      // Admins and Companies have full update rights on their shipments.
      // Couriers can ONLY update specific fields on their assigned shipments.
      allow update: if (isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid)) ||
                       (isCourier() && resource.data.assignedCourierId == request.auth.uid && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));

      allow delete: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
    }
    
    // Admins can manage all payments. Couriers can only read their own payments.
    match /courier_payments/{paymentId} {
      allow read: if isAdmin() || (isCourier() && resource.data.courierId == request.auth.uid);
      allow write: if isAdmin();
    }
    
     // Admins can manage all payments. Companies can only read their own payments.
    match /company_payments/{paymentId} {
      allow get: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Chat ---
    match /chats/{chatId} {
      // Allow read/update if the user is a participant.
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      // Allow creation if the user is creating a chat for themselves.
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      // A user can read/write messages if they are a participant of the parent chat.
      match /messages/{messageId} {
      	allow read, write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Role collections are managed exclusively by admins for creating non-admin users.
    match /roles_company/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_courier/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    // Static data collections are readable by any signed-in user, but only writable by admins.
    match /governorates/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /companies/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
     match /couriers/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
