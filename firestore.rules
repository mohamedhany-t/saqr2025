
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }

    function isCompany() {
      return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Static/Public Data ---
    match /governorates/{docId} {
      allow read: if isSignedIn();
    }
    match /companies/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /couriers/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Shipments ---
    match /shipments/{shipmentId} {
      allow read: if isAdmin() ||
                     (isCompany() && resource.data.companyId == request.auth.uid) ||
                     (isCourier() && resource.data.assignedCourierId == request.auth.uid);
      allow create: if isAdmin() || (isCompany() && request.resource.data.companyId == request.auth.uid);
      allow update: if isAdmin() ||
                     (isCompany() && resource.data.companyId == request.auth.uid) ||
                     (isCourier() && resource.data.assignedCourierId == request.auth.uid && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));
      allow delete: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
    }
    
    // --- Chat ---
    match /conversations/{conversationId} {
      // Allow LIST queries only if they are filtered by the user's UID.
      // This is crucial to prevent users from listing all conversations.
      allow list: if isSignedIn() && request.query.where.participantIds.includes(request.auth.uid);
      
      // Allow GET, CREATE, UPDATE on individual documents only if the user is a participant.
      allow get, update, create: if isSignedIn() && request.auth.uid in resource.data.participantIds;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds
                      && request.auth.uid == request.resource.data.senderId;
      // Messages are immutable
      allow update, delete: if false;
    }


    // --- Role Collections ---
    // Only Admins can manage roles (via creating users with roles)
    // Direct client modification of roles is denied unless you are an admin.
    match /roles_admin/{docId} { allow read, write: if isAdmin(); }
    match /roles_company/{docId} { allow read, write: if isAdmin(); }
    match /roles_courier/{docId} { allow read, write: if isAdmin(); }
  }
}

    