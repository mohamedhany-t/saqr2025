rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return get(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid)).data != null;
    }
    
    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }
    
    function isCompany() {
       return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Admin Access ---
    // Admins have full read/write access to everything.
    match /{path=**} {
      allow read, write: if isAdmin();
    }
    
    // ---- Static Data ----
    // Any signed-in user can read governorates.
    match /governorates/{governorateId} {
      allow read: if isSignedIn();
    }

    // --- Company Access ---
    match /users/{userId} {
        allow read: if isSignedIn();
        allow update: if isOwner(userId);
    }
    
    match /companies/{companyId} {
        allow read: if isSignedIn();
        allow update: if isOwner(companyId) && isCompany();
    }
    
    match /couriers/{courierId} {
        allow read: if isSignedIn();
        allow update: if isOwner(courierId) && isCourier();
    }

    match /shipments/{shipmentId} {
      allow read: if (isCompany() && resource.data.companyId == request.auth.uid)
                  || (isCourier() && resource.data.assignedCourierId == request.auth.uid);

      allow create: if isCompany();
      
      allow update: if (isCompany() && resource.data.companyId == request.auth.uid)
                    || (isCourier() 
                        && resource.data.assignedCourierId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));

      allow delete: if isCompany() && resource.data.companyId == request.auth.uid;
    }

    // --- Courier Access ---
    match /chats/{courierId} {
      allow read, write: if isOwner(courierId);
      
      match /messages/{messageId} {
        allow read, write: if isOwner(courierId);
      }
    }
  }
}
