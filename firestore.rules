rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isAdmin() {
      // Check if the user has an admin role document.
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isCompany() {
       return exists(/databases/$(database)/documents/roles_company/$(request.auth.uid));
    }

    function isCourier() {
       return exists(/databases/$(database)/documents/roles_courier/$(request.auth.uid));
    }
    
    // Rules for 'users' collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_company/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_courier/{userId} {
      allow read, write: if isAdmin();
    }
    
    // Rules for 'shipments' collection
    match /shipments/{shipmentId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isCompany();
      allow update: if isAdmin() || isCourier() || (isCompany() && resource.data.companyId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // Rules for 'companies' collection
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    // Rules for 'couriers' collection
    match /couriers/{courierId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    // Rules for 'governorates' collection
    match /governorates/{governorateId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
     match /custom_statuses/{statusId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    // Rules for 'courier_payments' and 'company_payments'
    match /courier_payments/{paymentId} {
      allow read, create, update, delete: if isAdmin();
    }
    match /company_payments/{paymentId} {
       allow read, create, update, delete: if isAdmin();
    }
    
    // Rules for 'chats' and 'messages'
    match /chats/{chatId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      
      match /messages/{messageId} {
         allow read, create: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
         allow update, delete: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }
    
    match /users/{userId}/pushSubscriptions/{subscriptionId} {
        allow read, write: if isOwner(userId);
    }
  }
}
