
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isRole(role) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isRole('admin');
    }

    // Shipments:
    // Admin: Can do anything.
    // Company: Can create, can read/update their own shipments. Cannot delete.
    // Courier: Can read their assigned shipments, can only update status and specific fields.
    match /shipments/{shipmentId} {
      allow read: if isAuthenticated();
      allow create: if isRole('admin') || isRole('company');
      allow update: if isAdmin() || 
                       (isRole('company') && resource.data.companyId == request.auth.uid) ||
                       (isRole('courier') && request.auth.uid == resource.data.assignedCourierId && request.resource.data.keys().hasOnly(['status', 'reason', 'updatedAt', 'paidAmount', 'courierCommission', 'companyCommission', 'collectedAmount']));
      allow delete: if isAdmin();
    }
    
    // Users:
    // Admin: Can read/write/delete any user.
    // Others: Can only read their own user document.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // Companies & Couriers public data
    // Anyone can read. Only admin can modify.
    match /companies/{companyId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin();
    }
    match /couriers/{courierId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAdmin();
    }
    
    // Governorates:
    // Anyone can read. Only admin can modify.
    match /governorates/{governorateId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Payments (Company & Courier)
    // Admin can do anything.
    // Company/Courier can only read their own payments.
    match /company_payments/{paymentId} {
        allow read: if isAdmin() || (isRole('company') && resource.data.companyId == request.auth.uid);
        allow create, update, delete: if isAdmin();
    }
     match /courier_payments/{paymentId} {
        allow read: if isAdmin() || (isRole('courier') && resource.data.courierId == request.auth.uid);
        allow create, update, delete: if isAdmin();
    }
    
    // Roles collections for role-based access control
    // Only readable by admin to verify roles, not writable by client.
     match /roles_admin/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Managed server-side
    }
     match /roles_company/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Managed server-side
    }
     match /roles_courier/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Managed server-side
    }
    
    // Chat & Messages
    match /chats/{chatId} {
      // Allow read/write if user is a participant in the chat
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }
    match /chats/{chatId}/messages/{messageId} {
       // Allow read/write if user is a participant in the parent chat
      allow read, write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    // Push Subscriptions
    // Users can only manage their own subscriptions
    match /users/{userId}/pushSubscriptions/{subscriptionId} {
        allow read, write, delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Settings
    // Admin can write, any authenticated user can read
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
