
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    function isCompany() {
      return exists(/databases/$(database)/documents/roles_company/$(request.auth.uid));
    }
    function isCourier() {
      return exists(/databases/$(database)/documents/roles_courier/$(request.auth.uid));
    }
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    // SETTINGS & GOVERNORATES: Readable by signed-in users, writable only by admins.
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /governorates/{govId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // CUSTOM_STATUSES: Readable by all, writable only by admins.
    match /custom_statuses/{statusId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // USERS, COMPANIES, COURIERS: Admins can do anything. Others can read the list.
    match /users/{userId} {
        allow read, write, delete: if isAdmin();
        allow get, list: if isSignedIn();
    }
    match /companies/{companyId} {
       allow read, write, delete: if isAdmin();
       allow get, list: if isSignedIn();
    }
     match /couriers/{courierId} {
       allow read, write, delete: if isAdmin();
       allow get, list: if isSignedIn();
    }
    
    // SHIPMENTS: Complex logic based on role.
    match /shipments/{shipmentId} {
      // Admin can do anything.
      allow read, write, create, delete: if isAdmin();
      
      // Company can create, and read/update their own shipments.
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid;
      allow read, update: if isCompany() && resource.data.companyId == request.auth.uid;

      // Courier can read/update their assigned shipments.
      allow read, update: if isCourier() && resource.data.assignedCourierId == request.auth.uid;
    }

    // PAYMENTS: Admins can do anything. Involved party can read.
    match /courier_payments/{paymentId} {
        allow read, write, create, delete: if isAdmin();
        allow list: if isAdmin(); // Only admin can list all payments
    }
    match /company_payments/{paymentId} {
        allow read, write, create, delete: if isAdmin();
        allow list: if isAdmin();
    }

    // CHATS: Participants can read/write messages. Admin can oversee.
    match /chats/{chatId} {
      allow read, update: if request.auth.uid in resource.data.participants || isAdmin();
      allow create: if isSignedIn();

      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin();
      }
    }

    // USER-SPECIFIC SUBCOLLECTIONS (like Push Subscriptions)
    match /users/{userId}/{subcollection}/{docId} {
        allow read, write: if request.auth.uid == userId;
    }

    // ROLE DOCUMENTS: Only admin can manage roles.
    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /roles_company/{userId} { allow read, write: if isAdmin(); }
    match /roles_courier/{userId} { allow read, write: if isAdmin(); }
  }
}
