
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      // Check if a document exists for the user in the specified role collection.
      return exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }
    
    function isCompany() {
       return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ---- USERS & PROFILES ----
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isOwner(userId);
    }
    
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || (isCompany() && companyId == request.auth.uid);
    }

    match /couriers/{courierId} {
       allow read: if isSignedIn(); // Added read permission to prevent rule conflicts
       allow create, update: if isAdmin() || (isCourier() && courierId == request.auth.uid);
    }
    
    // ---- CHAT ----
    // Admin has full access to all chats and messages.
    // Couriers can only access their own chat thread.
    match /chats/{courierId} {
      allow read, write: if isAdmin() || isOwner(courierId);

      match /messages/{messageId} {
        allow read, write: if isAdmin() || isOwner(courierId);
      }
    }
    
    // ---- SHIPMENTS ----
    match /shipments/{shipmentId} {
      allow read: if isAdmin()
                  || (isCompany() && resource.data.companyId == request.auth.uid)
                  || (isCourier() && resource.data.assignedCourierId == request.auth.uid);
                  
      allow create: if isAdmin() || isCompany();
      
      // Admin: full update access.
      // Company: can update their own shipments.
      // Courier: can only update specific fields like status, reason, and financial amounts.
      allow update: if isAdmin()
                    || (isCompany() && request.resource.data.companyId == request.auth.uid)
                    || (isCourier() 
                        && request.resource.data.assignedCourierId == request.auth.uid 
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));

      allow delete: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
    }

    // ---- STATIC DATA & ROLE MANAGEMENT ----
    match /governorates/{governorateId} {
      // Allow any signed-in user to read the list of governorates.
      allow read: if isSignedIn();
    }
    
    // Admins can manage all roles.
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_company/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_courier/{userId} {
      allow read, write: if isAdmin();
    }
  }
}
