rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }

    function isCompany() {
      return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // --- Global Admin Catch-All (HIGHEST PRIORITY) ---
    // This rule gives admins God-mode. It's evaluated alongside specific rules.
    // If ANY rule passes (this one or a specific one), access is granted.
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId);
      // Admin can update via global rule
    }

    // --- Static/Public Data ---
    match /governorates/{docId} {
      allow read: if isSignedIn();
    }
    match /companies/{docId} {
      allow read: if isSignedIn();
    }
    match /couriers/{docId} {
      allow read: if isSignedIn();
    }

    // --- Shipments ---
    match /shipments/{shipmentId} {
      allow read: if isCompany() && resource.data.companyId == request.auth.uid ||
                     isCourier() && resource.data.assignedCourierId == request.auth.uid;
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid;
      allow update: if (isCompany() && resource.data.companyId == request.auth.uid) ||
                    (isCourier() && resource.data.assignedCourierId == request.auth.uid && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));
      allow delete: if isCompany() && resource.data.companyId == request.auth.uid;
       // Admin access is covered by the global rule
    }

    // --- Chat ---
    // These rules apply if the user is NOT an admin. The global admin rule will grant access anyway.
    match /chats/{courierId} {
      allow read, write: if isOwner(courierId); // Courier can read/write their own chat document
      
      // Explicit rule for messages subcollection
      match /messages/{messageId} {
         // Allow if user is the owner of the chat, OR if the user is an admin.
         // This is the most explicit way to solve the permission issue.
        allow read, write: if isOwner(courierId) || isAdmin();
      }
    }
    
    // --- Role Collections ---
    // Deny all direct access by default. Admin access is granted by the global rule.
    match /roles_admin/{docId} { allow read, write: if false; }
    match /roles_company/{docId} { allow read, write: if false; }
    match /roles_courier/{docId} { allow read, write: if false; }
  }
}
