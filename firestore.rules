/**
 * @fileoverview Firestore Security Rules for AlSaqr Logistics application.
 *
 * Core Philosophy:
 * This ruleset prioritizes authorization independence through denormalization.
 * It enforces role-based access control using dedicated collections for admin, company, and courier roles.
 * Structural segregation is used to ensure that each collection has consistent security requirements.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles and their roles.
 * - /shipments/{shipmentId}: Stores shipment data with denormalized fields for filtering.
 * - /companies/{companyId}: Stores company information (previously clients).
 * - /subclients/{subClientId}: Stores sub-client information.
 * - /deliveryCompanies/{companyId}: Stores logistics company information.
 * - /couriers/{courierId}: Stores courier information.
 * - /governorates/{governorateId}: Stores governorate information.
 * - /roles_admin/{userId}: Grants admin role to the user.
 * - /roles_company/{userId}: Grants company role to the user.
 * - /roles_courier/{userId}: Grants courier role to the user.
 *
 * Key Security Decisions:
 * - Read-only collections (companies, subclients, deliveryCompanies, couriers, governorates) are publicly readable.
 * - Shipment writes are restricted to users with appropriate roles.
 * - Role assignments are managed through the existence of documents in the role collections.
 *
 * Denormalization for Authorization:
 * - Shipments denormalize 'governorateId', 'companyId', 'subClientId', 'assignedCompanyId', and 'assignedCourierId' to avoid `get()` calls in security rules.
 *
 * Structural Segregation:
 * - User roles are stored in separate collections (/roles_admin, /roles_company, /roles_courier) to simplify security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user has the admin role.
     * @return {boolean} True if the user has the admin role, false otherwise.
     */
    function isAdmin() {
      // Grant admin access to a specific email for development and if user has admin role
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == "mhanyt21@gmail.com"
      );
    }
    
    /**
     * @description Checks if the user has the company role.
     * @return {boolean} True if the user has the company role, false otherwise.
     */
    function isCompany() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_company/$(request.auth.uid));
    }
    
     /**
     * @description Checks if the user has the courier role.
     * @return {boolean} True if the user has the courier role, false otherwise.
     */
    function isCourier() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_courier/$(request.auth.uid));
    }

    /**
     * @description Checks if the user ID matches the requested user ID.
     * @param {string} userId The user ID to check against.
     * @return {boolean} True if the user ID matches, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    /**
     * @description Rules for the /users collection.
     * @path /users/{userId}
     * @allow (read, write) - Admins can manage all user profiles.
     * @allow create - A user can create their own profile document, or an admin can create it.
     */
    match /users/{userId} {
      allow read, update, delete: if isAdmin();
      allow create: if isSignedIn() && (isOwner(userId) || isAdmin());
    }
    
    /**
     * @description Rules for the /shipments collection.
     * @path /shipments/{shipmentId}
     */
    match /shipments/{shipmentId} {
      allow read: if isAdmin() 
                  || (isCompany() && resource.data.companyId == request.auth.uid) 
                  || (isCourier() && resource.data.assignedCourierId == request.auth.uid);
      allow create: if isAdmin() || isCompany();
      allow update: if isAdmin()
                    || (isCompany() && request.resource.data.companyId == request.auth.uid)
                    || (isCourier() && request.resource.data.assignedCourierId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt']));
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for the /companies collection (previously clients).
     * @path /companies/{companyId}
     * @allow (read) - Any signed-in user can read company data.
     * @allow (write) - Admins can write.
     */
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Rules for the /deliveryCompanies collection.
     * @path /deliveryCompanies/{companyId}
     * @allow (read) - Any signed-in user can read company data.
     * @allow (write) - Admins can write.
     */
    match /deliveryCompanies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Rules for the /subclients collection.
     * @path /subclients/{subClientId}
     * @allow (read) - Any signed-in user can read subclient data.
     * @allow (write) - Admins can write.
     */
    match /subclients/{subClientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Rules for the /couriers collection.
     * @path /couriers/{courierId}
     * @allow (read) - Any signed-in user can read courier data.
     * @allow (write) - Admins can write.
     */
    match /couriers/{courierId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Rules for the /governorates collection.
     * @path /governorates/{governorateId}
     * @allow (read) - Any signed-in user can read governorate data.
     * @allow (write) - Admins can write.
     */
    match /governorates/{governorateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Rules for the /roles_admin collection.
     * Admin role management. Admins can read/write all roles.
     */
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Rules for the /roles_company collection.
     * Company role management. Admins can read/write all roles.
     */
    match /roles_company/{userId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Rules for the /roles_courier collection.
     * Courier role management. Admins can read/write all roles.
     */
    match /roles_courier/{userId} {
      allow read, write: if isAdmin();
    }
  }
}
