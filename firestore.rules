rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      // Use exists() for a robust check that doesn't depend on document content.
      return exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }

    function isCompany() {
      return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Admin Catch-All ---
    // A single, powerful rule to grant admins full access to everything.
    // This rule is evaluated, and if it passes, access is granted without
    // checking more specific, potentially conflicting rules below.
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // --- User Profiles ---
    // Any signed-in user can read any profile.
    // A user can only update their own profile.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId);
      // Create/Delete is handled by admin rule.
    }

    // --- Static/Public Data ---
    // Any signed-in user can read these collections.
    // Writes are admin-only (covered by the catch-all).
    match /governorates/{docId} {
      allow read: if isSignedIn();
    }
    match /companies/{docId} {
      allow read: if isSignedIn();
    }
    match /couriers/{docId} {
      allow read: if isSignedIn();
    }

    // --- Shipments ---
    // These rules are for non-admin users.
    match /shipments/{shipmentId} {
      // Company can read its own shipments.
      // Courier can read shipments assigned to them.
      allow read: if (isCompany() && resource.data.companyId == request.auth.uid) ||
                    (isCourier() && resource.data.assignedCourierId == request.auth.uid);

      // Company can create shipments for itself.
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid;

      // Company can update its own shipments.
      // Courier can only update status, reason, and financial fields on assigned shipments.
      allow update: if (isCompany() && resource.data.companyId == request.auth.uid) ||
                    (isCourier()
                        && resource.data.assignedCourierId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));

      // Company can delete its own shipments.
      allow delete: if isCompany() && resource.data.companyId == request.auth.uid;
    }

    // --- Chat ---
    // These rules are for non-admin users.
    match /chats/{courierId} {
      // A courier can access their own chat document and its messages subcollection.
      allow read, write: if isCourier() && isOwner(courierId);

      match /messages/{messageId} {
        allow read, write: if isCourier() && isOwner(courierId);
      }
    }

    // --- Role Documents ---
    // Lock down role collections. Writes should only be done by admin (covered by catch-all).
    // No one else should be able to read or write these.
    match /roles_admin/{docId} { allow read, write: if false; }
    match /roles_company/{docId} { allow read, write: if false; }
    match /roles_courier/{docId} { allow read, write: if false; }
  }
}
