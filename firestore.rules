
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles
    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isRole(role) {
      return isUserAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      return isRole('admin');
    }
    
    function isCompany() {
      return isRole('company');
    }
    
    function isCourier() {
      return isRole('courier');
    }

    // Settings: Readable by all authenticated, writable only by admin
    match /settings/{settingId} {
      allow read: if isUserAuthenticated();
      allow write: if isAdmin();
    }
    
    // Governorates: Readable by all authenticated, writable only by admin
    match /governorates/{governorateId} {
        allow read: if isUserAuthenticated();
        allow write: if isAdmin();
    }

    // Users:
    match /users/{userId} {
      // Admins can manage all users. Users can read their own data.
      allow read: if isAdmin() || request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // Companies & Couriers collections store public profile data.
    // Let any authenticated user read them (e.g., to populate dropdowns).
    // Only admins can create/update/delete these profiles.
    match /companies/{companyId} {
       allow read: if isUserAuthenticated();
       allow write: if isAdmin();
    }
    
    match /couriers/{courierId} {
       allow read: if isUserAuthenticated();
       allow write: if isAdmin();
    }

    // Shipments
    match /shipments/{shipmentId} {
      // Admins can do anything.
      allow read, delete, create, update: if isAdmin();

      // Companies can create shipments, and read/update their own.
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid;
      allow read, update: if isCompany() && resource.data.companyId == request.auth.uid;
      
      // Couriers can read/update shipments assigned to them.
      allow read, update: if isCourier() && resource.data.assignedCourierId == request.auth.uid;
    }

    // Payments: Only Admins can manage payments.
    // The relevant user (courier/company) should be able to read their own payments.
    match /courier_payments/{paymentId} {
        allow read: if isAdmin() || (isCourier() && resource.data.courierId == request.auth.uid);
        allow write: if isAdmin();
    }

    match /company_payments/{paymentId} {
        allow read: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
        allow write: if isAdmin();
    }
    
    // Chats
    match /chats/{chatId} {
        // Only participants of the chat can access it
        allow read, write: if isUserAuthenticated() && request.auth.uid in resource.data.participants;

        match /messages/{messageId} {
            allow read, write: if isUserAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }
    }
    
    // Push Subscriptions: Users can only manage their own subscriptions.
    match /users/{userId}/pushSubscriptions/{subscriptionId} {
        allow read, write, delete: if request.auth.uid == userId;
    }
  }
}
