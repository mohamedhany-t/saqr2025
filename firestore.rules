rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }

    function isCompany() {
      return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isShipmentOwner(shipmentDoc) {
        return isCompany() && shipmentDoc.companyId == request.auth.uid;
    }
    
    function isShipmentCourier(shipmentDoc) {
        return isCourier() && shipmentDoc.assignedCourierId == request.auth.uid;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow update: if isOwner(userId);
      // Admin can write/delete via global rule
    }

    // --- Static/Public Data ---
    match /governorates/{docId} {
      allow read: if isSignedIn();
    }
    match /companies/{docId} {
      allow read: if isSignedIn();
    }
    match /couriers/{docId} {
      allow read: if isSignedIn();
    }

    // --- Shipments ---
    match /shipments/{shipmentId} {
      allow read: if isShipmentOwner(resource.data) || isShipmentCourier(resource.data) || isAdmin();
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid || isAdmin();
      allow update: if isAdmin() || isShipmentOwner(resource.data) ||
                    (isShipmentCourier(resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));
      allow delete: if isShipmentOwner(resource.data) || isAdmin();
    }

    // --- Chat ---
    // Rules that explicitly check for admin OR owner. This prevents the more
    // specific rule from overriding the admin's global access.
    match /chats/{courierId} {
      allow read, write: if isAdmin() || isOwner(courierId);
      
      match /messages/{messageId} {
        allow read, write: if isAdmin() || isOwner(courierId);
      }
    }
    
    // --- Admin-only & Role Collections ---
    // The most secure way: deny all direct access by default.
    // Admin access is granted by the global rule below.
    match /roles_admin/{docId} { allow read, write: if false; }
    match /roles_company/{docId} { allow read, write: if false; }
    match /roles_courier/{docId} { allow read, write: if false; }

    // --- Global Admin Catch-All ---
    // This rule gives admins God-mode. It's evaluated alongside specific rules.
    // If ANY rule passes (this one or a specific one), access is granted.
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
