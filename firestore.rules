
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isRole(role) {
      return exists(/databases/$(database)/documents/roles_$(role)/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isSignedIn() && isRole('admin');
    }
    
    function isCompany() {
       return isSignedIn() && isRole('company');
    }

    function isCourier() {
      return isSignedIn() && isRole('courier');
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ---- CHAT ----
    match /chats/{chatId}/messages/{messageId} {
        allow read, create: if isAdmin() || (isCourier() && chatId == request.auth.uid);
        allow update, delete: if isAdmin() || (isCourier() && request.auth.uid == resource.data.senderId);
    }

    match /chats/{chatId} {
      allow read, write: if isAdmin() || (isCourier() && chatId == request.auth.uid);
    }
    
    // ---- USERS & PROFILES ----
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || isOwner(userId);
    }
    
    match /companies/{companyId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || (isCompany() && companyId == request.auth.uid);
    }

    match /couriers/{courierId} {
       allow read: if isSignedIn();
       allow create, update: if isAdmin() || (isCourier() && courierId == request.auth.uid);
    }

    // ---- SHIPMENTS ----
    match /shipments/{shipmentId} {
      allow read: if isAdmin()
                  || (isCompany() && resource.data.companyId == request.auth.uid)
                  || (isCourier() && resource.data.assignedCourierId == request.auth.uid);
      allow create: if isAdmin() || isCompany();
      allow update: if isAdmin()
                    || (isCompany() && resource.data.companyId == request.auth.uid)
                    || (isCourier() && request.resource.data.assignedCourierId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reason', 'updatedAt', 'collectedAmount', 'courierCommission', 'paidAmount']));
      allow delete: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
    }

    // ---- STATIC & ROLES ----
    match /governorates/{governorateId} {
      allow read: if isSignedIn();
    }
    
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_company/{userId} {
      allow read, write: if isAdmin();
    }
    match /roles_courier/{userId} {
      allow read, write: if isAdmin();
    }
  }
}
