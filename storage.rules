
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Default deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Allow users to upload chat attachments if they are authenticated.
    // The path is structured as 'chat_attachments/{chatId}/{fileName}'
    match /chat_attachments/{chatId}/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
